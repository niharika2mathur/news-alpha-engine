# ============================================================
# .env.example – Copy to .env and fill in your keys
# ============================================================

# ── LLM API Keys (required) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE        # optional fallback

# ── Databases ──────────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://postgres:password@localhost:5432/newsalpha
POSTGRES_PASSWORD=password
MONGODB_URL=mongodb://localhost:27017/newsalpha
REDIS_URL=redis://localhost:6379/0

# ── News Data Sources ──────────────────────────────────────────
NEWSAPI_KEY=YOUR_NEWSAPI_ORG_KEY_HERE          # newsapi.org (free tier: 100 req/day)
ALPHAVANTAGE_KEY=YOUR_ALPHAVANTAGE_KEY_HERE    # optional: for real-time prices

# ── App Settings ───────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ── LLM Tuning ─────────────────────────────────────────────────
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
LLM_BATCH_SIZE=10
LLM_MAX_CONCURRENT=20
